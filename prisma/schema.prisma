// ───────────────────────────────────────────────────────────────────────────
//  ORA PADS — Unified Control & Impact Platform
//  Prisma schema · PostgreSQL
//
//  Design principles encoded here:
//   • Products carry NO price column — pricing is per-request, admin-assigned.
//   • Every stock change is an immutable StockMovement (no "invisible stock").
//   • Requests (not carts) drive distribution: PENDING → PRICED → APPROVED.
//   • Admin is the only financial authority (pricing, credit, returns).
// ───────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // App runtime: Neon POOLED connection (…-pooler…). Local: your Postgres URL.
  url       = env("DATABASE_URL")
  // Migrations / db push: Neon DIRECT connection. Local: same as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  FINANCE // Finance & Accounting dept — daily financial ops, reports to admin
  WAREHOUSE
  PARTNER
  SALES_REP
}

enum UserStatus {
  PENDING // awaiting admin approval (agents/partners start here)
  ACTIVE
  SUSPENDED
}

enum ProductCategory {
  PADS
  HYGIENE
  ACCESSORY
  OTHER
}

enum MovementType {
  INBOUND // stock received into the warehouse
  ASSIGNED // reserved/assigned to an agent or order
  DISTRIBUTED // shipped out / fulfilled to the field
  RETURNED // physically returned from agent/user
  RESTOCKED // approved return placed back into the warehouse
  ADJUSTMENT // manual correction by admin
}

enum RequestType {
  AGENT_STOCK // bulk stock request from an agent/partner
  USER_PRODUCT // product request from a general user
}

enum RequestStatus {
  PENDING // submitted, awaiting admin review
  PRICED // admin assigned prices, awaiting final approval
  APPROVED // approved & invoiced; moves straight to IN_TRANSIT
  IN_TRANSIT // dispatched — warehouse preparing / delivering
  REJECTED
  FULFILLED // delivered & confirmed — inventory now decremented
  CANCELLED
}

enum PaymentType {
  IMMEDIATE
  CREDIT
}

enum PaymentStatus {
  UNPAID // not yet due (pre-delivery)
  PAID // cash order, settled on delivery
  OUTSTANDING // credit order, balance owed
}

enum CreditStatus {
  OUTSTANDING
  PARTIAL
  SETTLED
  OVERDUE
}

enum ReturnStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  APPROVED
  REJECTED
}

enum DonationType {
  PADS
  MONEY
}

enum DonationStatus {
  PENDING // received request / pledge
  RECEIVED // funds/goods confirmed
  ALLOCATED // earmarked for a beneficiary group
  DISTRIBUTED // delivered to the field
  CANCELLED
}

enum ContentCategory {
  MENSTRUAL_HEALTH
  HYGIENE
  MYTHS_FACTS
  COMMUNITY_STORY
  GENERAL
}

enum Language {
  EN
  SW
}

// ── Identity ───────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  name               String
  phone              String?
  role               Role       @default(PARTNER)
  status             UserStatus @default(ACTIVE)
  organization       String? // business/partner name for partners
  location           String?
  creditLimit        Int? // admin-set credit ceiling (whole TSh) for partners
  creditScore        Int        @default(0) // grows with each successfully repaid credit cycle
  creditCycles       Int        @default(0) // completed borrow→repay-in-full cycles
  notes              String? // internal admin notes
  financeNotes       String? // finance's notes on the partner's creditworthiness
  applicationNote    String? // applicant-facing: info the ORA team has requested
  businessType       String? // Agent / Distributor / NGO / School / Retail chain
  region             String?
  district           String? // administrative district within the region
  street             String? // street / physical address line
  expectedVolume     String? // expected monthly purchase volume
  preferredPayment   String? // Cash / Credit
  businessLicense    String? // licence number
  taxId              String? // TIN / tax number
  paymentTerms       String? // admin-set terms, e.g. "Net 30"
  preferredName      String? // nickname used in greetings, e.g. "Recy"
  avatar             String? // profile photo (/uploads/... or blob URL)
  lastLoginAt        DateTime?
  sessionVersion     Int        @default(0) // bump to sign the user out everywhere
  assignedWarehouse  String? // partner's fulfilling warehouse (admin-set, denormalised name); orders default here, hidden from the customer
  warehouse          Warehouse? @relation("WarehouseStaff", fields: [warehouseId], references: [id])
  warehouseId        String? // for WAREHOUSE staff — the warehouse they operate
  position           String? // job title for warehouse staff, e.g. "Stock Controller"
  // Operational permission flags for warehouse staff (admin-configured).
  canRecordSales     Boolean    @default(false)
  canCreateTransfers Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  requestsMade          Request[]                @relation("RequestRequester")
  requestsReviewed      Request[]                @relation("RequestReviewer")
  movementsCreated      StockMovement[]          @relation("MovementCreator")
  donationsMade         Donation[]               @relation("DonationDonor")
  donationsHandled      Donation[]               @relation("DonationHandler")
  returnsMade           ReturnRequest[]          @relation("ReturnRequester")
  returnsReviewed       ReturnRequest[]          @relation("ReturnReviewer")
  creditAccounts        CreditAccount[]          @relation("CreditAgent")
  creditsApproved       CreditAccount[]          @relation("CreditApprover")
  paymentsRecorded      Payment[]                @relation("PaymentRecorder")
  cycleLogs             CycleLog[]
  activityLogs          ActivityLog[]            @relation("ActivityActor")
  educationAuthored     EducationContent[]       @relation("ContentAuthor")
  newsAuthored          NewsPost[]               @relation("NewsAuthor")
  partnerPrices         PartnerPrice[]           @relation("PartnerPrices")
  transfersCreated      WarehouseTransfer[]      @relation("TransferCreator")
  settlementsSubmitted  SettlementRequest[]      @relation("SettlementPartner")
  settlementsReviewed   SettlementRequest[]      @relation("SettlementReviewer")
  contactMessages       ContactMessage[]         @relation("ContactSender")
  // Field sales (SALES_REP)
  repStock              RepStock[]               @relation("RepStockRep")
  repIssuesReceived     RepStockIssue[]          @relation("RepIssueRep")
  repIssuesGiven        RepStockIssue[]          @relation("RepIssuer")
  repStockRequests      RepStockRequest[]        @relation("RepStockRequestRep")
  repRequestsPrepared   RepStockRequest[]        @relation("RepRequestPreparer")
  fieldCustomers        FieldCustomer[]          @relation("RepCustomers")
  fieldSales            FieldSale[]              @relation("RepSales")
  fieldPaymentsRecorded FieldPayment[]           @relation("FieldPaymentRecorder")
  fieldSalesReviewed    FieldSale[]              @relation("FieldSaleReviewer")
  fieldPaymentsReviewed FieldPayment[]           @relation("FieldPaymentReviewer")
  cashDeposits          CashDeposit[]            @relation("CashDepositCreator")
  extensionsRequested   CreditExtensionRequest[] @relation("ExtensionRequester")
  extensionsReviewed    CreditExtensionRequest[] @relation("ExtensionReviewer")
  sampleLogs            SampleLog[]              @relation("RepSamples")
  fieldReports          FieldReport[]            @relation("RepReports")
  repTargets            RepTarget[]              @relation("RepTargets")
  // Finance
  expensesRecorded      Expense[]                @relation("ExpenseRecorder")
  capitalRecorded       CapitalEntry[]           @relation("CapitalRecorder")
  pettyCashRequested    PettyCashRequest[]       @relation("PettyCashRequester")
  pettyCashApproved     PettyCashRequest[]       @relation("PettyCashApprover")
  pettyCashSpent        PettyCashExpense[]       @relation("PettyCashSpender")
  payrollCreated        PayrollRun[]             @relation("PayrollCreator")
  payrollApproved       PayrollRun[]             @relation("PayrollApprover")
  // Impact
  impactActivities      ImpactActivity[]         @relation("ImpactActivityCreator")
  loginEvents           LoginEvent[]
  creditEvents          PartnerCreditEvent[]     @relation("PartnerCreditEvents")

  @@index([role])
  @@index([status])
}

/// Auditable history of a partner's credit facility: manual limit changes,
/// automatic 10% growth, and completed repayment cycles.
enum CreditEventType {
  LIMIT_SET // admin manually set/changed the limit
  LIMIT_INCREASE // automatic growth after a successful cycle
  CYCLE_COMPLETED // outstanding balance repaid in full
}

model PartnerCreditEvent {
  id        String          @id @default(cuid())
  partner   User            @relation("PartnerCreditEvents", fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId String
  type      CreditEventType
  prevLimit Int? // limit before the event (TSh)
  newLimit  Int? // limit after the event (TSh)
  score     Int? // credit score after the event
  cycles    Int? // completed cycles after the event
  note      String? // human-readable reason, e.g. "Cycle 3 repaid on time"
  createdAt DateTime        @default(now())

  @@index([partnerId])
  @@index([type])
}

/// One row per successful sign-in — powers the profile's login history.
model LoginEvent {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ── Impact activities ──────────────────────────────────────────────────────
//  ORA is not a fundraising platform: impact is measured in pads distributed,
//  girls supported and communities visited. Every activity recorded here
//  updates the public impact statistics automatically.

enum ImpactActivityType {
  SCHOOL_VISIT
  COMMUNITY_OUTREACH
  EDUCATION_SESSION
  AWARENESS_CAMPAIGN
  PAD_DISTRIBUTION
  OTHER
}

model ImpactActivity {
  id              String             @id @default(cuid())
  title           String
  type            ImpactActivityType @default(COMMUNITY_OUTREACH)
  description     String?
  location        String // school / community / venue
  region          String?
  district        String?
  partnerOrg      String? // partner organisation, if any
  padsDistributed Int                @default(0)
  peopleReached   Int                @default(0)
  images          String[]           @default([])
  activityDate    DateTime           @default(now())
  isPublished     Boolean            @default(true)
  createdBy       User?              @relation("ImpactActivityCreator", fields: [createdById], references: [id])
  createdById     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([isPublished])
  @@index([activityDate])
  @@index([type])
}

/// Per-partner negotiated price for a product (TSh per unit). Set by admin at
/// approval and editable from the partner profile. Partners only ever see their own.
model PartnerPrice {
  id        String   @id @default(cuid())
  partner   User     @relation("PartnerPrices", fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  price     Int
  updatedAt DateTime @updatedAt

  @@unique([partnerId, productId])
  @@index([partnerId])
}

/// Physical Ora warehouses. WAREHOUSE staff are assigned to one.
enum WarehouseStatus {
  ACTIVE
  OFFLINE
  MAINTENANCE
}

enum TransferStatus {
  PENDING
  APPROVED
  IN_TRANSIT
  COMPLETED
  REJECTED
}

model Warehouse {
  id        String          @id @default(cuid())
  name      String
  location  String?
  isActive  Boolean         @default(true)
  status    WarehouseStatus @default(ACTIVE)
  capacity  Int? // total unit capacity for utilisation %
  createdAt DateTime        @default(now())

  staff            User[]              @relation("WarehouseStaff")
  stock            WarehouseStock[]
  transfersOut     WarehouseTransfer[] @relation("TransferFrom")
  transfersIn      WarehouseTransfer[] @relation("TransferTo")
  repStockRequests RepStockRequest[]   @relation("RepRequestWarehouse")
}

// Per-warehouse location ledger. Seeded from current org-wide totals into the
// Main warehouse; transfers move quantities between warehouses. The org-wide
// Inventory snapshot remains the source of truth for fulfillment.
model WarehouseStock {
  id          String    @id @default(cuid())
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId String
  product     Product   @relation(fields: [productId], references: [id])
  productId   String
  onHand      Int       @default(0)
  reserved    Int       @default(0)
  inTransit   Int       @default(0)
  minLevel    Int       @default(50)
  lastMoveAt  DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@index([warehouseId])
}

model WarehouseTransfer {
  id           String         @id @default(cuid())
  code         String         @unique
  from         Warehouse      @relation("TransferFrom", fields: [fromId], references: [id])
  fromId       String
  to           Warehouse      @relation("TransferTo", fields: [toId], references: [id])
  toId         String
  status       TransferStatus @default(PENDING)
  note         String?
  createdBy    User           @relation("TransferCreator", fields: [createdById], references: [id])
  createdById  String
  approvedById String?
  dispatchedAt DateTime?
  receivedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  items WarehouseTransferItem[]

  @@index([status])
}

model WarehouseTransferItem {
  id         String            @id @default(cuid())
  transfer   WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  transferId String
  product    Product           @relation(fields: [productId], references: [id])
  productId  String
  quantity   Int
}

// ── Catalogue & inventory ──────────────────────────────────────────────────

model Product {
  id             String          @id @default(cuid())
  sku            String          @unique
  name           String
  description    String?
  category       ProductCategory @default(PADS)
  unitLabel      String          @default("pack") // e.g. "pack of 8"
  iconKey        String          @default("pads") // maps to a UI icon, never an external image
  unitsPerCarton Int             @default(24) // pieces in one carton — cartons are a display unit, stock is stored in pieces
  costPrice      Int             @default(0) // internal buying cost per piece (TSh)
  price          Int             @default(0) // standard selling price per piece (TSh) — never public
  notForSale     Boolean         @default(false) // e.g. free sample packs — no selling price, excluded from order/sell flows
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  inventory            Inventory?
  movements            StockMovement[]
  requestItems         RequestItem[]
  returnRequests       ReturnRequest[]
  partnerPrices        PartnerPrice[]
  warehouseStock       WarehouseStock[]
  transferItems        WarehouseTransferItem[]
  repStock             RepStock[]
  repIssues            RepStockIssue[]
  repStockRequestItems RepStockRequestItem[]
  fieldSaleItems       FieldSaleItem[]
  sampleLogs           SampleLog[]

  @@index([category])
  @@index([isActive])
}

/// Running snapshot of stock per product. Mutated only through StockMovements,
/// so warehouse + assigned + distributed always reconciles with the ledger.
model Inventory {
  id                String   @id @default(cuid())
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId         String   @unique
  warehouseQty      Int      @default(0) // available, unassigned stock
  assignedQty       Int      @default(0) // committed to active orders, not yet distributed
  distributedQty    Int      @default(0) // cumulative distributed to the field
  lowStockThreshold Int      @default(50)
  updatedAt         DateTime @updatedAt
}

// ── Receiving accounts ──────────────────────────────────────────────────────

/// Where money physically lands: cash offices, bank accounts, mobile-money
/// merchant numbers. Admin-managed; every payment records which account
/// received the funds so finance can reconcile against real balances.
enum PaymentAccountType {
  CASH
  BANK
  MOBILE_MONEY
}

model PaymentAccount {
  id            String             @id @default(cuid())
  name          String // provider / location: "NMB Bank", "Voda", "Cash"
  type          PaymentAccountType
  accountName   String? // holder shown to payers, e.g. "ORA Sanitary Pads"
  accountNumber String? // bank account number or Lipa number
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  fieldSales         FieldSale[]
  fieldPayments      FieldPayment[]
  payments           Payment[]
  settlementRequests SettlementRequest[]
  requests           Request[]
  pettyCashRequests  PettyCashRequest[]
  payrollRuns        PayrollRun[]
  cashDeposits       CashDeposit[]

  @@index([type])
  @@index([isActive])
}

/// Immutable ledger of every physical stock change.
model StockMovement {
  id            String       @id @default(cuid())
  product       Product      @relation(fields: [productId], references: [id])
  productId     String
  type          MovementType
  quantity      Int
  reference     String? // free-text reference (e.g. delivery note)
  request       Request?     @relation(fields: [requestId], references: [id])
  requestId     String?
  note          String?
  warehouseName String? // the warehouse this movement physically involved
  createdBy     User         @relation("MovementCreator", fields: [createdById], references: [id])
  createdById   String
  createdAt     DateTime     @default(now())

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([warehouseName])
}

// ── Request-based orders ───────────────────────────────────────────────────

model Request {
  id               String          @id @default(cuid())
  code             String          @unique
  type             RequestType
  status           RequestStatus   @default(PENDING)
  paymentType      PaymentType     @default(IMMEDIATE)
  requester        User            @relation("RequestRequester", fields: [requesterId], references: [id])
  requesterId      String
  note             String? // requester message / special instructions
  adminNote        String?
  deliverTo        String? // delivery destination / recipient name
  deliveryAddress  String? // full delivery address
  contactName      String? // person to contact on delivery
  contactPhone     String? // contact phone number
  deliverBy        DateTime? // preferred delivery date
  warehouseName    String? // fulfilling warehouse (denormalized label)
  discount         Int             @default(0) // whole TSh off the order
  deliveryCharge   Int             @default(0) // whole TSh added for delivery
  paymentStatus    PaymentStatus   @default(UNPAID)
  paymentClaimedAt DateTime? // customer pressed "I have made payment" — awaiting admin verification
  // How and where the order's money was received (counter sales record it at
  // creation; partner orders at admin payment confirmation).
  paymentMethod    String?
  paymentAccount   PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  paymentAccountId String?
  paymentReference String?
  paidAt           DateTime? // when the money was confirmed received
  invoiceNo        String? // generated on approval
  deliveredAt      DateTime? // delivery confirmation
  totalAmount      Int? // computed once priced (whole KES)
  reviewedBy       User?           @relation("RequestReviewer", fields: [reviewedById], references: [id])
  reviewedById     String?
  reviewedAt       DateTime?
  fulfilledAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  items          RequestItem[]
  creditAccount  CreditAccount?
  movements      StockMovement[]
  returnRequests ReturnRequest[]

  @@index([status])
  @@index([requesterId])
  @@index([type])
}

model RequestItem {
  id        String  @id @default(cuid())
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  unitPrice Int? // admin-assigned; null until PRICED
  lineTotal Int? // quantity * unitPrice

  @@unique([requestId, productId])
}

// ── Credit ─────────────────────────────────────────────────────────────────

model CreditAccount {
  id           String       @id @default(cuid())
  request      Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId    String       @unique
  agent        User         @relation("CreditAgent", fields: [agentId], references: [id])
  agentId      String
  principal    Int // total owed (whole KES)
  amountPaid   Int          @default(0)
  status       CreditStatus @default(OUTSTANDING)
  wentOverdue  Boolean      @default(false) // sticky: ever flagged overdue (blocks automatic limit growth for the cycle)
  dueDate      DateTime?
  approvedBy   User?        @relation("CreditApprover", fields: [approvedById], references: [id])
  approvedById String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  payments           Payment[]
  settlementRequests SettlementRequest[]

  @@index([status])
  @@index([agentId])
}

model Payment {
  id               String          @id @default(cuid())
  creditAccount    CreditAccount   @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)
  creditAccountId  String
  amount           Int
  method           String? // cash, mobile money, bank
  paymentAccount   PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  paymentAccountId String? // which company account received the funds
  reference        String? // transaction reference (optional)
  note             String?
  recordedBy       User            @relation("PaymentRecorder", fields: [recordedById], references: [id])
  recordedById     String
  createdAt        DateTime        @default(now())

  @@index([creditAccountId])
  @@index([paymentAccountId])
}

enum SettlementStatus {
  PENDING
  CONFIRMED
  REJECTED
}

// A partner-submitted payment claim against a credit batch. The ORA team
// confirms it (→ creates a Payment & reduces the balance) or rejects it.
model SettlementRequest {
  id               String           @id @default(cuid())
  code             String           @unique
  partner          User             @relation("SettlementPartner", fields: [partnerId], references: [id])
  partnerId        String
  creditAccount    CreditAccount    @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)
  creditAccountId  String
  amount           Int
  method           String?
  // Which company account the partner says they paid into — pre-selects the
  // receiving account when the admin confirms.
  paymentAccount   PaymentAccount?  @relation(fields: [paymentAccountId], references: [id])
  paymentAccountId String?
  reference        String?
  note             String?
  status           SettlementStatus @default(PENDING)
  reviewedBy       User?            @relation("SettlementReviewer", fields: [reviewedById], references: [id])
  reviewedById     String?
  reviewedAt       DateTime?
  paymentId        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status])
  @@index([partnerId])
}

enum ContactStatus {
  OPEN
  RESOLVED
}

// Partner → ORA team message thread (one message + optional reply).
model ContactMessage {
  id          String        @id @default(cuid())
  sender      User          @relation("ContactSender", fields: [senderId], references: [id])
  senderId    String
  subject     String?
  body        String
  status      ContactStatus @default(OPEN)
  reply       String?
  repliedById String?
  repliedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([senderId])
}

// ── Returns ────────────────────────────────────────────────────────────────

model ReturnRequest {
  id               String       @id @default(cuid())
  code             String       @unique
  request          Request?     @relation(fields: [requestId], references: [id])
  requestId        String?
  product          Product      @relation(fields: [productId], references: [id])
  productId        String
  requester        User         @relation("ReturnRequester", fields: [requesterId], references: [id])
  requesterId      String
  quantity         Int
  reason           String?
  reasonType       String?
  warehouseName    String?
  status           ReturnStatus @default(PENDING)
  reviewedBy       User?        @relation("ReturnReviewer", fields: [reviewedById], references: [id])
  reviewedById     String?
  reviewedAt       DateTime?
  receivedAt       DateTime?
  adminNote        String?
  // Finance-initiated debt-recovery return: goods taken back to settle an
  // outstanding field credit sale. On receipt, creditValue is applied to the
  // linked sale's balance (reduces accounts receivable).
  financeInitiated Boolean      @default(false)
  fieldSale        FieldSale?   @relation(fields: [fieldSaleId], references: [id])
  fieldSaleId      String?
  creditValue      Int? // TSh recovered off the debt when the return completes
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([status])
  @@index([requesterId])
  @@index([fieldSaleId])
}

// ── Donations (ARCHIVED) ───────────────────────────────────────────────────
//  ORA no longer accepts monetary donations. These tables are retained only
//  as the historical record of past NTZS payments — no UI or API uses them.

model DonationPackage {
  id           String       @id @default(cuid())
  name         String
  description  String?
  type         DonationType
  amount       Int? // preset money (whole KES)
  padsQuantity Int? // preset pads count
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())

  donations Donation[]
}

model Donation {
  id             String           @id @default(cuid())
  code           String           @unique
  type           DonationType
  donorName      String
  donorEmail     String?
  donor          User?            @relation("DonationDonor", fields: [donorId], references: [id])
  donorId        String? // null = guest donation
  package        DonationPackage? @relation(fields: [packageId], references: [id])
  packageId      String?
  amount         Int? // for MONEY
  quantity       Int? // for PADS
  message        String?
  status         DonationStatus   @default(PENDING)
  allocationNote String?
  distributedTo  String? // beneficiary group / region
  handledBy      User?            @relation("DonationHandler", fields: [handledById], references: [id])
  handledById    String?
  // ── NTZS payment (mobile money → ORA treasury) ──
  donorPhone     String? // payer mobile number
  ntzsUserId     String? // NTZS payer user id
  ntzsDepositId  String? // NTZS deposit id (matched by the webhook)
  txHash         String? // on-chain settlement reference
  paidAt         DateTime? // when payment was confirmed
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([ntzsDepositId])
}

// ── Education & impact ─────────────────────────────────────────────────────

model EducationContent {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  excerpt     String
  body        String // long-form (plain text / light markdown)
  category    ContentCategory @default(MENSTRUAL_HEALTH)
  language    Language        @default(EN)
  readMinutes Int             @default(3)
  published   Boolean         @default(true)
  sortOrder   Int             @default(0)
  author      User?           @relation("ContentAuthor", fields: [authorId], references: [id])
  authorId    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@index([language])
  @@index([published])
}

enum NewsCategory {
  NEWS
  ANNOUNCEMENT
  EVENT
  STORY
}

model NewsPost {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  excerpt     String
  body        String // long-form (plain text / light markdown)
  category    NewsCategory @default(NEWS)
  coverImage  String? // /uploads/... or /ora/... path
  published   Boolean      @default(true)
  publishedAt DateTime     @default(now())
  author      User?        @relation("NewsAuthor", fields: [authorId], references: [id])
  authorId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([category])
  @@index([published])
  @@index([publishedAt])
}

model ImpactStory {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  personName      String?
  location        String?
  quote           String?
  body            String
  padsDistributed Int?
  livesReached    Int?
  published       Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published])
}

// ── Period tracker (private, per user) ─────────────────────────────────────

model CycleLog {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  lastPeriodDate DateTime
  cycleLength    Int      @default(28)
  periodLength   Int      @default(5)
  notes          String?
  createdAt      DateTime @default(now())

  @@index([userId])
}

// ── Governance ─────────────────────────────────────────────────────────────

/// Append-only audit trail surfaced in the admin "full activity logs".
model ActivityLog {
  id        String   @id @default(cuid())
  actor     User?    @relation("ActivityActor", fields: [actorId], references: [id])
  actorId   String?
  actorName String? // snapshot in case the user is later removed
  action    String // machine code, e.g. REQUEST_APPROVED
  entity    String // e.g. Request, Donation, Inventory
  entityId  String?
  summary   String // human-readable line
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
}

/// Simple key/value store for admin-configurable settings (org info, baselines).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Field sales (Sales Rep module) ─────────────────────────────────────────
//  Warehouse → Sales Rep → Customer. Every unit is traceable:
//  RepStockIssue (immutable) moves stock to a rep; FieldSale / SampleLog
//  consume it. RepStock is the per-rep snapshot, reconciled by those ledgers.

enum RepStockKind {
  SELLABLE // stock issued for selling (cash or credit)
  SAMPLE // free-distribution sample stock
}

enum FieldSaleType {
  CASH
  CREDIT
}

/// Lifecycle of PHYSICAL cash after finance confirms receipt from a rep.
/// Only set for cash-method transactions; bank/mobile/cheque money lands
/// straight in an account and never enters cash-on-hand (stays null).
enum CashStatus {
  RECEIVED // finance confirmed the cash in hand — revenue recognised, awaiting deposit
  DEPOSITED // batched into a CashDeposit and banked
}

enum FieldCreditStatus {
  PENDING // credit sale, nothing (or only part) collected yet
  PARTIAL
  PAID
  OVERDUE
}

enum RepStockRequestStatus {
  PENDING // waiting for warehouse / admin review
  READY // approved & prepared — stock reserved, awaiting rep pickup
  ISSUED // collected and confirmed by the rep — stock transferred
  REJECTED
}

/// Per-rep, per-product stock snapshot. Mutated only via issues/sales/samples.
model RepStock {
  id          String   @id @default(cuid())
  rep         User     @relation("RepStockRep", fields: [repId], references: [id], onDelete: Cascade)
  repId       String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  sellableQty Int      @default(0) // in hand, available to sell
  sampleQty   Int      @default(0) // in hand, available to give as samples
  receivedQty Int      @default(0) // cumulative received from warehouse
  soldQty     Int      @default(0) // cumulative units sold
  sampledQty  Int      @default(0) // cumulative samples distributed
  updatedAt   DateTime @updatedAt

  @@unique([repId, productId])
  @@index([repId])
}

/// Immutable record of stock issued from the warehouse to a rep.
model RepStockIssue {
  id            String       @id @default(cuid())
  code          String       @unique
  rep           User         @relation("RepIssueRep", fields: [repId], references: [id])
  repId         String
  product       Product      @relation(fields: [productId], references: [id])
  productId     String
  kind          RepStockKind @default(SELLABLE)
  quantity      Int
  note          String?
  issuedBy      User         @relation("RepIssuer", fields: [issuedById], references: [id])
  issuedById    String
  warehouseName String? // where the rep collected (immutable label)
  createdAt     DateTime     @default(now())

  @@index([repId])
  @@index([createdAt])
}

/// A rep's request for more stock — one request can span several products.
/// Warehouse staff (or admin) approve & prepare it (READY, stock reserved);
/// the rep collects at the warehouse and confirms receipt (ISSUED).
model RepStockRequest {
  id           String                @id @default(cuid())
  code         String                @unique
  rep          User                  @relation("RepStockRequestRep", fields: [repId], references: [id])
  repId        String
  note         String?
  status       RepStockRequestStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  // Collection trail: which warehouse prepared it, who, and when the rep
  // collected — full traceability of every handover.
  warehouse    Warehouse?            @relation("RepRequestWarehouse", fields: [warehouseId], references: [id])
  warehouseId  String?
  preparedBy   User?                 @relation("RepRequestPreparer", fields: [preparedById], references: [id])
  preparedById String?
  preparedAt   DateTime?
  collectedAt  DateTime?
  createdAt    DateTime              @default(now())

  items RepStockRequestItem[]

  @@index([status])
  @@index([repId])
  @@index([warehouseId])
}

/// One product line within a rep's stock request. Quantities are in PIECES;
/// cartons are entered in the UI and converted before saving.
model RepStockRequestItem {
  id        String          @id @default(cuid())
  request   RepStockRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId String
  product   Product         @relation(fields: [productId], references: [id])
  productId String
  kind      RepStockKind    @default(SELLABLE)
  quantity  Int // pieces requested
  issuedQty Int             @default(0) // pieces actually issued when fulfilled

  @@unique([requestId, productId])
  @@index([requestId])
}

/// A rep's field customer. Each customer belongs to exactly ONE sales rep
/// (the rep who created them) — customer books are never shared between reps.
model FieldCustomer {
  id               String   @id @default(cuid())
  name             String
  businessName     String? // trading name, e.g. "ABC Pharmacy"
  email            String?
  phone            String?
  location         String? // street / physical address — default delivery address
  region           String? // administrative region, e.g. "Dar es Salaam"
  district         String? // administrative district within the region
  customerType     String? // Pharmacy / Shop / Supermarket / Kiosk / …
  expectedVolume   String? // expected monthly purchase volume, e.g. "500 packs"
  preferredPayment String? // Cash / Credit
  businessLicense  String? // licence number (optional)
  taxId            String? // TIN / tax number (optional)
  creditLimit      Int? // per-customer credit cap, set by ADMIN/FINANCE only (null = uncapped). Enforced on credit sales.
  gpsLat           Float? // captured on creation when the device allows it
  gpsLng           Float?
  notes            String?
  rep              User     @relation("RepCustomers", fields: [repId], references: [id])
  repId            String
  creditSuspended  Boolean  @default(false) // admin can cut off credit access
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sales            FieldSale[]
  creditExtensions CreditExtensionRequest[]

  @@index([repId])
}

/// A field sale (cash or credit). Stock is deducted atomically on creation.
/// Finance is the financial control point: rep-recorded money is PENDING
/// until finance verifies it landed (cash) or the credit terms hold (credit).
/// Only APPROVED rows count as official revenue / receivables anywhere.
enum FinanceApproval {
  PENDING
  APPROVED
  REJECTED
}

model FieldSale {
  id                  String             @id @default(cuid())
  code                String             @unique
  type                FieldSaleType
  rep                 User               @relation("RepSales", fields: [repId], references: [id])
  repId               String
  customer            FieldCustomer?     @relation(fields: [customerId], references: [id])
  customerId          String? // required for CREDIT
  customerName        String? // optional walk-in name for CASH sales
  location            String?
  total               Int // whole TSh
  amountPaid          Int                @default(0) // CASH ⇒ equals total
  creditStatus        FieldCreditStatus? // null for CASH sales
  paymentMethod       String? // CASH sales: Cash / Bank Transfer / Mobile Money
  paymentAccount      PaymentAccount?    @relation(fields: [paymentAccountId], references: [id])
  paymentAccountId    String? // which company account received the cash
  reference           String? // transaction reference (optional)
  // CHEQUE payments capture the instrument details for finance to verify.
  chequeBank          String?
  chequeNumber        String?
  chequeDate          DateTime?
  dueDate             DateTime?
  note                String?
  // Finance verification — the gate between a rep's record and company money.
  financeStatus       FinanceApproval    @default(PENDING)
  financeReviewedBy   User?              @relation("FieldSaleReviewer", fields: [financeReviewedById], references: [id])
  financeReviewedById String?
  financeReviewedAt   DateTime?
  financeNote         String? // approval / rejection comment
  // Proof captured at confirmation: cash → bank deposit slip; direct
  // bank/Lipa payment → customer receipt reference or link.
  depositProofRef     String?
  // Uploaded proof IMAGE: for a direct bank/Lipa sale the rep attaches the
  // customer's receipt at point of sale; for a cash sale finance attaches the
  // bank deposit slip at confirmation.
  paymentProofUrl     String?
  // Physical-cash lifecycle (CASH-method sales only). null until finance
  // confirms cash received; RECEIVED = cash on hand; DEPOSITED = banked via a
  // CashDeposit. Bank/mobile/cheque money stays null (it's in an account).
  cashStatus          CashStatus?
  cashDeposit         CashDeposit?       @relation(fields: [cashDepositId], references: [id])
  cashDepositId       String?
  cashReceivedAt      DateTime? // when finance confirmed the cash in hand
  voided              Boolean            @default(false) // admin correction — restores stock
  voidReason          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  items            FieldSaleItem[]
  payments         FieldPayment[]
  returns          ReturnRequest[]
  creditExtensions CreditExtensionRequest[]

  @@index([repId])
  @@index([type])
  @@index([creditStatus])
  @@index([financeStatus])
  @@index([cashStatus])
  @@index([cashDepositId])
  @@index([createdAt])
}

model FieldSaleItem {
  id        String    @id @default(cuid())
  sale      FieldSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId    String
  product   Product   @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  unitPrice Int // TSh per unit at time of sale
  lineTotal Int

  @@index([saleId])
}

/// A collection against a credit sale (rep or admin records it).
model FieldPayment {
  id                  String          @id @default(cuid())
  sale                FieldSale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId              String
  amount              Int
  method              String? // cash, mobile money, bank
  paymentAccount      PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  paymentAccountId    String? // which company account received the funds
  reference           String? // transaction reference (optional)
  chequeBank          String? // CHEQUE collections capture instrument details
  chequeNumber        String?
  chequeDate          DateTime?
  note                String?
  recordedBy          User            @relation("FieldPaymentRecorder", fields: [recordedById], references: [id])
  recordedById        String
  // Rep-recorded collections stay PENDING (and unapplied to the sale balance)
  // until finance verifies the money; finance/admin records auto-approve.
  financeStatus       FinanceApproval @default(PENDING)
  financeReviewedBy   User?           @relation("FieldPaymentReviewer", fields: [financeReviewedById], references: [id])
  financeReviewedById String?
  financeReviewedAt   DateTime?
  financeNote         String?
  // Deposit slip / receipt reference captured when finance verifies.
  depositProofRef     String?
  // Uploaded proof image (customer receipt / deposit slip).
  paymentProofUrl     String?
  // Physical-cash lifecycle (cash collections only) — mirrors FieldSale.
  cashStatus          CashStatus?
  cashDeposit         CashDeposit?    @relation(fields: [cashDepositId], references: [id])
  cashDepositId       String?
  cashReceivedAt      DateTime?
  createdAt           DateTime        @default(now())

  @@index([saleId])
  @@index([financeStatus])
  @@index([paymentAccountId])
  @@index([cashStatus])
  @@index([cashDepositId])
}

/// A finance-raised request to extend a credit sale's due date. Finance creates
/// it after reviewing the customer; ADMIN approves/rejects. On approval the
/// sale's dueDate moves and its credit status is recomputed. History is kept.
enum ExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

model CreditExtensionRequest {
  id               String          @id @default(cuid())
  sale             FieldSale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId           String
  customer         FieldCustomer?  @relation(fields: [customerId], references: [id])
  customerId       String?
  originalDueDate  DateTime?
  outstanding      Int // TSh outstanding when the extension was requested
  reason           String
  requestedDueDate DateTime
  financeNotes     String?
  status           ExtensionStatus @default(PENDING)
  requestedBy      User            @relation("ExtensionRequester", fields: [requestedById], references: [id])
  requestedById    String
  reviewedBy       User?           @relation("ExtensionReviewer", fields: [reviewedById], references: [id])
  reviewedById     String?
  reviewedAt       DateTime?
  adminNote        String?
  createdAt        DateTime        @default(now())

  @@index([saleId])
  @@index([customerId])
  @@index([status])
}

/// A weekly/monthly bank deposit that banks a BATCH of already-received cash.
/// Finance selects cash sales + collections that are RECEIVED (on hand) and
/// deposits them together into one company account, attaching the deposit slip.
model CashDeposit {
  id               String         @id @default(cuid())
  code             String         @unique // e.g. DEP-3F7K2Q
  depositAccount   PaymentAccount @relation(fields: [depositAccountId], references: [id])
  depositAccountId String // the company bank account the cash was banked into
  total            Int // whole TSh — sum of the linked cash (computed server-side)
  depositDate      DateTime // date the cash was physically banked
  slipRef          String? // deposit slip number / bank reference
  slipUrl          String? // uploaded deposit-slip image
  note             String?
  depositedBy      User           @relation("CashDepositCreator", fields: [depositedById], references: [id])
  depositedById    String
  createdAt        DateTime       @default(now())

  fieldSales    FieldSale[]
  fieldPayments FieldPayment[]

  @@index([depositAccountId])
  @@index([depositDate])
}

/// Free-sample distribution record — deducts the rep's sample stock.
model SampleLog {
  id        String   @id @default(cuid())
  rep       User     @relation("RepSamples", fields: [repId], references: [id])
  repId     String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  location  String?
  reason    String? // campaign or reason
  createdAt DateTime @default(now())

  @@index([repId])
  @@index([createdAt])
}

/// Daily field report submitted by a rep, visible to admin in real time.
model FieldReport {
  id              String   @id @default(cuid())
  rep             User     @relation("RepReports", fields: [repId], references: [id])
  repId           String
  reportDate      DateTime @default(now())
  location        String
  salesAchieved   Int      @default(0) // TSh recorded that day
  unitsSold       Int      @default(0)
  creditCollected Int      @default(0) // TSh collected from debtors
  challenges      String?
  marketFeedback  String?
  createdAt       DateTime @default(now())

  @@index([repId])
  @@index([reportDate])
}

// ── Stockists & coverage ───────────────────────────────────────────────────

enum StockistType {
  PHARMACY
  SUPERMARKET
  SHOP
  CLINIC
  SCHOOL
  NGO
  OTHER
}

/// A physical outlet where ORA products are available — powers the public
/// "Find ORA" coverage map. Admin-managed; the map updates automatically.
model Stockist {
  id        String       @id @default(cuid())
  name      String
  type      StockistType @default(SHOP)
  region    String
  district  String
  address   String?
  phone     String?
  hours     String? // e.g. "Mon–Sat 8:00–20:00"
  lat       Float? // explicit pin; falls back to district/region point
  lng       Float?
  products  String? // e.g. "Night 360 · Day 290 · Liners"
  image     String?
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([region])
  @@index([district])
  @@index([isActive])
  @@index([type])
}

// ── Finance ────────────────────────────────────────────────────────────────
//  Income is DERIVED from the operational tables (sales, collections,
//  donations) so it can never drift out of sync. Only money going OUT
//  (expenses) and capital coming IN are recorded here directly.

enum ExpenseCategory {
  // Operational
  RENT
  UTILITIES
  STATIONERY
  OFFICE
  // Staff
  SALARIES
  ALLOWANCES
  TRANSPORT_REIMBURSEMENT
  // Logistics
  DELIVERY
  WAREHOUSE_HANDLING
  TRANSPORT_OF_GOODS
  // Business
  STOCK_PURCHASE
  IMPORT_COSTS
  PACKAGING
  MARKETING
  TAXES
  INTERNET
  EQUIPMENT
  OTHER
}

enum CapitalType {
  FOUNDER_INVESTMENT
  INVESTMENT
  PROFIT_REINVESTED
  GRANT
  OTHER
}

/// Where an Expense row originated — lets the Operational Fund net only its own
/// spend, and reports still count every Expense once as money-out.
enum ExpenseSource {
  DIRECT // a plain company expense (or legacy)
  OPERATIONAL_FUND // spent from the CEO-allocated Operational Fund
  PAYROLL // auto-created when a payroll run is paid
}

// ── Finance & Accounting department ─────────────────────────────────────────

enum PettyCashStatus {
  PENDING // finance requested, awaiting admin approval
  APPROVED // admin approved — money issued, expenditures being recorded
  REJECTED
  RECONCILED // finance submitted the reconciliation report
}

/// Petty cash accountability: finance requests an allocation, admin approves
/// (money leaves as an Expense at that moment), finance records every
/// expenditure against it, then closes it with a reconciliation report.
model PettyCashRequest {
  id               String          @id @default(cuid())
  code             String          @unique
  amount           Int // whole TSh allocated
  purpose          String
  // What kind of office spend this fund is for — files the resulting expense
  // under the right ledger category (defaults to OFFICE for older rows).
  category         ExpenseCategory @default(OFFICE)
  status           PettyCashStatus @default(PENDING)
  note             String? // requester's notes on the funding request
  requestedBy      User            @relation("PettyCashRequester", fields: [requestedById], references: [id])
  requestedById    String
  approvedBy       User?           @relation("PettyCashApprover", fields: [approvedById], references: [id])
  approvedById     String?
  approvedAt       DateTime?
  adminNote        String?
  // Which company account the cash was issued from.
  paymentAccount   PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  paymentAccountId String?
  reconciledAt     DateTime?
  reconcileNote    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  items    PettyCashRequestItem[]
  expenses PettyCashExpense[]

  @@index([status])
}

/// One planned line item on an office-fund request (the "cart"). The request's
/// amount is the sum; each item carries its own category so the issued expense
/// is filed correctly per line.
model PettyCashRequestItem {
  id          String           @id @default(cuid())
  request     PettyCashRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId   String
  category    ExpenseCategory  @default(OFFICE)
  description String
  amount      Int
  createdAt   DateTime         @default(now())

  @@index([requestId])
}

/// One expenditure recorded against a petty cash allocation.
model PettyCashExpense {
  id           String           @id @default(cuid())
  request      PettyCashRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId    String
  description  String
  amount       Int
  receiptRef   String? // receipt number / reference
  receiptUrl   String? // uploaded receipt / proof image
  recordedBy   User             @relation("PettyCashSpender", fields: [recordedById], references: [id])
  recordedById String
  createdAt    DateTime         @default(now())

  @@index([requestId])
}

/// Payroll staff registry — employees are paid people, not system logins.
model Employee {
  id         String   @id @default(cuid())
  name       String
  position   String?
  phone      String?
  baseSalary Int // monthly TSh
  isActive   Boolean  @default(true)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  payrollItems PayrollItem[]
}

enum PayrollStatus {
  DRAFT // finance building the run
  PENDING_APPROVAL // submitted to admin
  APPROVED // admin approved — ready to pay
  PAID // paid out — an Expense (SALARIES) was recorded
  REJECTED
}

/// One salary run (usually monthly). Paying it creates a SALARIES Expense so
/// payroll flows into every financial report automatically.
model PayrollRun {
  id               String          @id @default(cuid())
  code             String          @unique
  month            Int // 1-12
  year             Int
  status           PayrollStatus   @default(DRAFT)
  createdBy        User            @relation("PayrollCreator", fields: [createdById], references: [id])
  createdById      String
  approvedBy       User?           @relation("PayrollApprover", fields: [approvedById], references: [id])
  approvedById     String?
  approvedAt       DateTime?
  paidAt           DateTime?
  // Which company account the salaries were paid from.
  paymentAccount   PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  paymentAccountId String?
  note             String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  items PayrollItem[]

  @@index([status])
  @@index([year, month])
}

/// One employee's line on a payroll run (name & amounts snapshotted).
model PayrollItem {
  id         String     @id @default(cuid())
  run        PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId      String
  employee   Employee   @relation(fields: [employeeId], references: [id])
  employeeId String
  name       String // snapshot at run creation
  gross      Int
  allowance  Int        @default(0)
  deduction  Int        @default(0)
  net        Int

  @@index([runId])
}

/// Money leaving ORA — always categorised, always tied to the admin who
/// approved it. No expense exists without a record.
model Expense {
  id            String          @id @default(cuid())
  code          String          @unique
  category      ExpenseCategory
  amount        Int // whole TSh
  purpose       String // description of the spend
  paymentMethod String? // cash, mobile money, bank
  source        ExpenseSource   @default(DIRECT) // where it came from (fund / payroll / direct)
  vendor        String? // vendor / recipient (optional)
  receiptRef    String? // receipt / invoice / voucher number
  receiptUrl    String? // uploaded supporting document
  expenseDate   DateTime        @default(now())
  note          String?
  recordedBy    User            @relation("ExpenseRecorder", fields: [recordedById], references: [id])
  recordedById  String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([category])
  @@index([source])
  @@index([expenseDate])
}

/// Capital injected into the business — founder money, investments,
/// reinvested profit — so growth over time is visible.
model CapitalEntry {
  id           String      @id @default(cuid())
  code         String      @unique
  type         CapitalType
  amount       Int // whole TSh
  source       String // who/where it came from
  note         String?
  entryDate    DateTime    @default(now())
  recordedBy   User        @relation("CapitalRecorder", fields: [recordedById], references: [id])
  recordedById String
  createdAt    DateTime    @default(now())

  @@index([type])
  @@index([entryDate])
}

/// Monthly targets per rep (admin-set), driving the rep's progress dashboard.
model RepTarget {
  id                   String   @id @default(cuid())
  rep                  User     @relation("RepTargets", fields: [repId], references: [id], onDelete: Cascade)
  repId                String
  year                 Int
  month                Int // 1–12
  salesTarget          Int      @default(0) // TSh
  unitsTarget          Int      @default(0)
  cashTarget           Int      @default(0) // TSh cash collection
  creditRecoveryTarget Int      @default(0) // TSh recovered from debtors
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([repId, year, month])
  @@index([repId])
}
