{
  "name": "ora-pads",
  "version": "0.1.0",
  "private": true,
  "description": "Ora Pads — controlled distribution, impact & education platform with full admin governance.",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:demo": "tsx prisma/seed-warehouse.ts && tsx prisma/seed-credit.ts && tsx prisma/seed-transfer.ts && tsx prisma/seed-orders.ts && node prisma/seed-news.cjs && node prisma/seed-stories.cjs",
    "db:seed:all": "npm run db:seed && npm run db:seed:demo",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && npm run db:seed:all",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@types/d3": "^7.4.3",
    "@vercel/blob": "^2.5.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.42.0",
    "lucide-react": "^0.469.0",
    "motion": "^12.42.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-use-measure": "^2.1.7",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.2.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
