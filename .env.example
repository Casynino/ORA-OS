# ───────────────────────────────────────────────────────────
# ORA OS — copy to .env (local) or set these in Vercel → Settings → Env Vars
# ───────────────────────────────────────────────────────────

# ── Database (Neon Postgres) ──────────────────────────────
# DATABASE_URL = the app runtime connection. On Neon use the POOLED string
#   (host contains "-pooler"). Append ?sslmode=require&pgbouncer=true.
# DIRECT_URL   = a DIRECT (non-pooled) connection, used only by Prisma
#   migrate / db push. On Neon use the connection WITHOUT "-pooler".
#
#   Local dev: point both at your local Postgres (same value is fine).
DATABASE_URL="postgresql://USER@localhost:5432/ora?schema=public"
DIRECT_URL="postgresql://USER@localhost:5432/ora?schema=public"

# Example Neon (production):
# DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.eu-central-1.aws.neon.tech/ora?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/ora?sslmode=require"

# ── Auth.js ───────────────────────────────────────────────
# Generate with:  openssl rand -base64 33
AUTH_SECRET=""
# Lets Auth.js trust the deployment host (required on Vercel).
AUTH_TRUST_HOST="true"

# ── File uploads (news cover images) ──────────────────────
# Created automatically when you add a Vercel Blob store to the project.
# Leave blank locally — uploads then fall back to /public/uploads.
BLOB_READ_WRITE_TOKEN=""

# ── Public app URL ────────────────────────────────────────
# Set to your real domain in production (used for share/links).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Executive WhatsApp reporting (CallMeBot) ──────────────
# Get an API key by messaging the CallMeBot number on WhatsApp (see callmebot.com).
# Phone = recipient (CEO) in international format, no "+". Both required to send.
CALLMEBOT_PHONE=""
CALLMEBOT_APIKEY=""
# Shared secret guarding the /api/cron/* report routes. Generate: openssl rand -hex 24
# Your external scheduler (cron-job.org) must send it as ?secret=... or a Bearer token.
CRON_SECRET=""
# Set to 1 to log WhatsApp messages instead of sending (local dev).
NOTIFICATIONS_DISABLED=""
